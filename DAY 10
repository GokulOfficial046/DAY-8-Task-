<!DOCTYPE html>
<html>
<head>
  <title>Flexbox Layout</title>
  <style>

    .container {
      display: flex;                 
      flex-direction: row;           
      justify-content: center;      
      align-items: center;           
      gap: 20px;
                       

      height: 300px;
      border: 2px solid black;
    }

    .box {
      width: 100px;
      height: 100px;
      background-color: steelblue;
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 20px;
        
    }
  </style>
</head>
<body>

  <div class="container">
    <div class="box">1</div>
    <div class="box">2</div>
    <div class="box">3</div>
  </div>

</body>
</html>